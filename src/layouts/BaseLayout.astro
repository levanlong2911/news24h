---
import HeaderAds from '../components/ads/HeaderAds.astro';
import Footer from '../components/Footer.astro';
import Navbar from '../components/Navbar.astro';
import '../styles/global.css';
import type { AdsMap } from '../types/ads';

const WEB_BASE = (import.meta.env.PUBLIC_API_WEB ?? '').replace(/\/$/, '');
const {
  pageTitle = 'News Day',
  pageDescription = 'Hot news, updated quickly and accurately every day.',
  pageImage = `${WEB_BASE}/default.jpg`,
  pageUrl = WEB_BASE,
  isArticle = false,
  publishedAt = '',
  updatedAt = '',
  authorName = 'News Day',
  ads = {} as AdsMap,
} = Astro.props;

---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>

    <!-- SEO -->
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={pageUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={pageImage} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content={isArticle ? 'article' : 'website'} />
    {isArticle && publishedAt && <meta property="article:published_time" content={publishedAt} />}
    {isArticle && (updatedAt || publishedAt) && <meta property="article:modified_time" content={updatedAt || publishedAt} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={pageImage} />

    <!-- Structured Data -->
    {isArticle && (
      <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "NewsArticle",
        headline: pageTitle,
        image: [pageImage],
        datePublished: publishedAt,
        dateModified: updatedAt || publishedAt,
        author: [{ "@type": "Person", name: authorName }],
      })} />
    )}
    <slot name="head" />
    <!-- HEADER ADS -->
    {ads?.header?.length && <HeaderAds ads={ads.header} />}

  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>

    <Footer />
    <script is:inline>
      (() => {
        const DEFAULT_TIMEOUT = 3500;
        const MIN_HEIGHT = 50;

        function checkSlot(slot) {
          const timeout =
            Number(slot.dataset.adsTimeout) || DEFAULT_TIMEOUT;

          setTimeout(() => {
            const iframes = slot.querySelectorAll("iframe");
            const height = slot.offsetHeight;

            if (!iframes.length || height < MIN_HEIGHT) {
              console.warn(
                "[ADS FAIL]",
                slot.dataset.adsPosition
              );
              slot.remove();
            } else {
              console.log(
                "[ADS OK]",
                slot.dataset.adsPosition
              );
            }
          }, timeout);
        }

        document
          .querySelectorAll(".ad-slot")
          .forEach(checkSlot);
      })();
    </script>

  </body>
</html>
